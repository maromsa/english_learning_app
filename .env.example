# Copy this file to `.env` and fill in the values for local development.
# NOTE: `.env` is only read on desktop/dev runs (via OS environment variables /
# dart-define). It is NOT bundled into the app. For release builds provide the
# same values via --dart-define.
#
# SECURITY: never add server-side secrets here (e.g. CLOUDINARY_API_SECRET).
# Anything compiled into the client binary can be extracted. Signed Cloudinary
# operations must happen server-side.

GEMINI_PROXY_URL=https://your-cloud-function-url.example.com/geminiProxy
AI_IMAGE_VALIDATION_URL=
PIXABAY_API_KEY=your_pixabay_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
GOOGLE_TTS_API_KEY=your_google_tts_api_key

# ElevenLabs TTS — kept entirely server-side (in Firebase Secret Manager).
# Run: firebase functions:secrets:set ELEVENLABS_API_KEY
# The client never sees this key; SparkVoiceService calls the proxy with mode=elevenlabs.
