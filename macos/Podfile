# Created by Flutter
require 'fileutils'

platform :osx, '11.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# flutter_sound macOS ships taudio.podspec; CocoaPods expects flutter_sound.podspec.
def ensure_flutter_sound_macos_podspec
  plugin_dir = File.expand_path('Flutter/ephemeral/.symlinks/plugins/flutter_sound/macos', __dir__)
  return unless File.directory?(plugin_dir)

  podspec_path = File.join(plugin_dir, 'flutter_sound.podspec')
  taudio_path = File.join(plugin_dir, 'taudio.podspec')
  unless File.exist?(podspec_path) || !File.exist?(taudio_path)
    content = File.read(taudio_path)
      .gsub("s.name             = 'taudio'", "s.name             = 'flutter_sound'")
      .gsub("s.version          = '0.0.1'", "s.version          = '9.30.0'")
    File.write(podspec_path, content)
  end

  # pubspec declares FlutterSoundPlugin; macOS only ships TaudioPlugin.swift.
  shim_path = File.join(plugin_dir, 'Classes', 'FlutterSoundPlugin.swift')
  unless File.exist?(shim_path)
    FileUtils.mkdir_p(File.dirname(shim_path))
    File.write(
      shim_path,
      <<~'SWIFT',
        import Cocoa
        import FlutterMacOS

        public class FlutterSoundPlugin: NSObject, FlutterPlugin {
          public static func register(with registrar: FlutterPluginRegistrar) {
            TaudioPlugin.register(with: registrar)
          }
        }
      SWIFT
    )
  end
end

ensure_flutter_sound_macos_podspec

target 'Runner' do
  use_frameworks!
  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# --- זהו הבלוק המאוחד והנכון ---
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '11.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end
end
